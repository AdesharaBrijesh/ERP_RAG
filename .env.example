# ---------------------------------------------------------------------------
# ERP RAG Chatbot - environment configuration
# Copy to .env and fill in. Never commit .env.
# ---------------------------------------------------------------------------

# --- Database ------------------------------------------------------------
# Admin/app connection: used for schema introspection, the rag.* schema
# (embeddings + sessions). NOT used to run generated SQL.
DATABASE_URL=postgresql+psycopg://postgres:Brijesh%40292@localhost:5432/erp_db

# Read-only connection: EVERY LLM-generated query runs through this role only.
# Created by `python -m scripts.bootstrap_db`.
READONLY_DATABASE_URL=postgresql+psycopg://erp_rag_ro:erp_rag_ro_pw@localhost:5432/erp_db

# --- LLM -----------------------------------------------------------------
# groq (local dev) | bedrock (production) | fake (offline tests)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Production target. Llama 3.3 70B on Bedrock.
BEDROCK_REGION=ap-south-1
BEDROCK_MODEL_ID=us.meta.llama3-3-70b-instruct-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# --- Embeddings ----------------------------------------------------------
# bedrock (production, Titan v2) | fastembed (local ONNX) | hashing (zero-dep fallback)
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval -----------------------------------------------------------
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.15
RETRIEVAL_FK_EXPANSION=true
RETRIEVAL_MAX_TABLES=8

# --- SQL execution guardrails (security-relevant) ------------------------
SQL_STATEMENT_TIMEOUT_MS=10000
SQL_MAX_ROWS=200
SQL_MAX_ROWS_TO_LLM=50

# --- Session state -------------------------------------------------------
# postgres (default, no extra infra) | redis
SESSION_BACKEND=postgres
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=86400
HISTORY_MAX_TURNS=8

# --- API security --------------------------------------------------------
# Comma-separated. Empty list disables auth (local dev only).
API_KEYS=local-dev-key
RATE_LIMIT_PER_MINUTE=30

# --- Cost reporting ------------------------------------------------------
USD_TO_INR=88.0

# --- Misc ----------------------------------------------------------------
LOG_LEVEL=INFO
ENV=local
